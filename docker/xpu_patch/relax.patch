+    # ------------------------------------------------------------------
+    # Explicit CPU offload for XPU (torch_memory_saver VMM pause is unsafe here).
+    # Reference: verl/utils/megatron_utils.py (offload_megatron_model_to_cpu, etc.)
+    # Uses typed storage API (.storage()) and attaches cpu_data to buffer objects,
+    # matching the pattern used by both Megatron-LM and verl.
+    # ------------------------------------------------------------------
+
+    def _iter_megatron_optimizers(self):
+        """Yield every Megatron DistributedOptimizer (unwrap ChainedOptimizer)."""
+        from megatron.core.optimizer import ChainedOptimizer
+
+        opt = self.optimizer
+        if isinstance(opt, ChainedOptimizer):
+            yield from opt.chained_optimizers
+        else:
+            yield opt
+
+    def _offload_train_to_cpu(self) -> None:
+        """Move model param/grad flat buffers, optimizer master params and state to CPU."""
+        import gc
+
+        # When Megatron's --optimizer-cpu-offload is active, HybridDeviceOptimizer
+        # manages its own CPU/GPU tensor placement. We must NOT move optimizer state
+        # ourselves or we break its invariants (_fused_adam device mismatch).
+        megatron_cpu_offload = getattr(self.args, "optimizer_cpu_offload", False)
+
+        # 1. Model DDP flat buffers
+        if self.model is not None:
+            for ddp_model in self.model:
+                for buffers in [
+                    getattr(ddp_model, "buffers", []) or [],
+                    getattr(ddp_model, "expert_parallel_buffers", []) or [],
+                ]:
+                    for buffer in buffers:
+                        # param_data: copy to CPU, then free GPU storage
+                        if buffer.param_data is not None and buffer.param_data.storage().size() > 0:
+                            buffer.param_data.cpu_data = buffer.param_data.data.cpu()
+                            buffer.param_data_size = buffer.param_data.storage().size()
+                            buffer.param_data.storage().resize_(0)
+                        # grad_data: just free GPU storage (contents discarded)
+                        if buffer.grad_data is not None and buffer.grad_data.storage().size() > 0:
+                            buffer.grad_data_size = buffer.grad_data.storage().size()
+                            buffer.grad_data.storage().resize_(0)
+
+        if not megatron_cpu_offload:
