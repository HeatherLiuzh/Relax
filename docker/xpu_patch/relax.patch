+                        elif group is not None and group.device.type != "cpu":
+                            group.data = group.data.to("cpu", non_blocking=False)
+
+            # 3. Optimizer Adam state (exp_avg, exp_avg_sq, etc.)
+            for _opt in self._iter_megatron_optimizers():
